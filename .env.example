# NCR Watchdog production configuration
# Frontend Cloudflare Pages URL this package is prepared for:
FRONTEND_URL=https://ncr-watchdog-dashboard.pages.dev/
DASHBOARD_URL=https://ncr-watchdog-dashboard.pages.dev/
ALLOWED_ORIGINS=https://ncr-watchdog-dashboard.pages.dev,https://ncr-watchdog-dashboard.pages.dev/

# Backend API base URL used by the Vite frontend build.
# Production uses the same Cloudflare Pages origin, where /api/* is proxied to the backend.
VITE_API_BASE_URL=https://ncr-watchdog-dashboard.pages.dev

# Cloudflare Pages Function proxy target for /api/*.
BACKEND_ORIGIN=http://35.196.168.113.sslip.io:3000

# Runtime port for the Express/tRPC backend.
PORT=3000
NODE_ENV=production

# Do not commit real secrets. Configure these on the backend host only when available.
# CF_API_TOKEN=
# CF_ZONE_ID=
# NCR_API_SECRET=
# TELEGRAM_BOT_TOKEN=
NCR_TELEGRAM_CHAT_ID=8741681815
TELEGRAM_CHAT_ID=8741681815
TELEGRAM_AUTHORIZED_CHAT_IDS=8741681815
