# Cloudflare Pages cache-busting policy: never cache the HTML shell so each deploy
# can point browsers at the newest hashed Vite asset bundle.
/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

# Hashed assets are safe to cache forever; filename changes bust stale JS/CSS.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
